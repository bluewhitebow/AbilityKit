<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>AbilityKit</RootNamespace>
    <AssemblyName>AbilityKit.Record</AssemblyName>
    <LangVersion>latest</LangVersion>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
  </PropertyGroup>

  <!-- 引用 Packages 目录下的源码 (排除有 Unity 直接引用的文件和依赖它们的文件) -->
  <ItemGroup>
    <!-- 排除有 UnityEngine 引用的文件及依赖它们的文件 -->
    <Compile Include="../../Unity/Packages/com.abilitykit.record/Runtime/**/*.cs" 
             Exclude="
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/LockstepOptimizedBinaryRecordCodec.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/LockstepJsonInputRecordWriter.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/LockstepJsonInputRecordReader.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/LockstepBinaryInputRecordWriter.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/LockstepBinaryInputRecordReader.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/LockstepJsonInputRecordCodec.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/LockstepBinaryInputRecordCodec.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/LockstepInputRecordFile.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/LockstepInputRecordCodecs.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/LockstepFrameRecordSink.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/LockstepInputRecordReplaySource.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/ILockstepInputRecordCodec.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Lockstep/ILockstepInputRecordWriter.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Core/Session/RecordFileStore.cs;
               ../../Unity/Packages/com.abilitykit.record/Runtime/Record/Core/Session/RecordSessionFactory.cs
             " />
  </ItemGroup>

  <!-- 项目引用 -->
  <ItemGroup>
    <ProjectReference Include="../../src/AbilityKit.Core/AbilityKit.Core.csproj" />
    <ProjectReference Include="../../src/AbilityKit.World.FrameSync/AbilityKit.World.FrameSync.csproj" />
    <ProjectReference Include="../../src/AbilityKit.Host/AbilityKit.Host.csproj" />
  </ItemGroup>

  <!-- NuGet 包引用 -->
  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

</Project>
