    <ProjectReference Include="..\AbilityKit.Demo.Moba.Core\AbilityKit.Demo.Moba.Core.csproj" />
</ItemGroup>
```

## 九、自动测试组件规范

### 9.1 自动测试组件设计原则

**ET Demo 使用自动测试组件验证核心流程（移动、技能释放）。**

```
┌─────────────────────────────────────────────────────────────────────────────┐
│ 自动测试组件定位 │
│ │
│ ┌───────────────────────────────────────────────────────────────────────┐ │
│ │ ETBattleAutoTestComponent │ │
│ │ 职责：模拟玩家移动输入，验证位置同步流程 │ │
│ │ 触发：每 N 帧发送 MoveCommand │ │
│ └───────────────────────────────────────────────────────────────────────┘ │
│ │
│ ┌───────────────────────────────────────────────────────────────────────┐ │
│ │ ETBattleSkillTestComponent │ │
│ │ 职责：模拟玩家技能释放，验证技能配置加载和触发器调用 │ │
│ │ 触发：每 N 帧发送 SkillCommand │ │
│ └───────────────────────────────────────────────────────────────────────┘ │
│ │
│ ┌───────────────────────────────────────────────────────────────────────┐ │
│ │ ETBattleDriverBridge │ │
│ │ 职责：驱动自动测试组件的更新，调用 ProcessInput │ │
│ │ 在 ETBattleDriverBridgeSystem.Update 中调用 │ │
│ └───────────────────────────────────────────────────────────────────────┘ │
└─────────────────────────────────────────────────────────────────────────────┘
```

### 9.2 自动测试组件命名

| 类型 | 命名规范 | 示例 |
|------|----------|------|
| 移动测试 Component | `ETBattleAutoTestComponent` | `ETBattleAutoTestComponent.cs` |
| 移动测试 System | `ETBattleAutoTestComponentSystem` | `ETBattleAutoTestComponentSystem.cs` |
| 技能测试 Component | `ETBattleSkillTestComponent` | `ETBattleSkillTestComponent.cs` |
| 技能测试 System | `ETBattleSkillTestComponentSystem` | `ETBattleSkillTestComponentSystem.cs` |

### 9.3 自动测试组件模板

**Component 模板：**

```csharp
[ComponentOf(typeof(Scene))]
public class ETBattleAutoTestComponent : Entity, IAwake, IUpdate, IDestroy
{
    // Is auto test enabled
    public bool IsEnabled { get; set; } = false;

    // Test parameters
    public long TestActorId { get; set; }
    public int TestIntervalFrames { get; set; } = 5; // Test interval

    // Internal state
    private int _currentFrame;
    private int _testCount;

    // Stats
    public int TestCount => _testCount;

    public void Awake()
    {
        Log.Info("[AutoTest] Component created");
    }

    /// <summary>
    /// Initialize auto test
    /// </summary>
    public void Initialize(long actorId)
    {
        TestActorId = actorId;
        _currentFrame = 0;
        _testCount = 0;
        Log.Info($"[AutoTest] Initialized for ActorId={actorId}");
    }

    public void Update() { }

    /// <summary>
    /// Every frame update
    /// </summary>
    public void OnUpdate(int frame)
    {
        if (!IsEnabled)
            return;

        _currentFrame = frame;

        if (_currentFrame % TestIntervalFrames == 0)
        {
            ExecuteTest();
            _testCount++;
        }
    }

    private void ExecuteTest()
    {
        // Test implementation
    }

    public void Destroy()
    {
        Log.Info($"[AutoTest] Destroyed. Total tests: {_testCount}");
    }
}
```

**System 模板：**

```csharp
[EntitySystemOf(typeof(ETBattleAutoTestComponent))]
[FriendOf(typeof(ETBattleAutoTestComponent))]
[FriendOf(typeof(ETInputComponent))]
public static partial class ETBattleAutoTestComponentSystem
{
    [EntitySystem]
    private static void Awake(this ETBattleAutoTestComponent self)
    {
        Log.Info("[AutoTest] System awake");
    }

    [EntitySystem]
    private static void Update(this ETBattleAutoTestComponent self) { }

    [EntitySystem]
    private static void Destroy(this ETBattleAutoTestComponent self)
    {
        Log.Info($"[AutoTest] System destroyed");
    }

    /// <summary>
    /// Enable auto test
    /// </summary>
    public static void Enable(this ETBattleAutoTestComponent self)
    {
        self.IsEnabled = true;
        Log.Info("[AutoTest] Auto test enabled");
    }

    /// <summary>
    /// Disable auto test
    /// </summary>
    public static void Disable(this ETBattleAutoTestComponent self)
    {
        self.IsEnabled = false;
        Log.Info("[AutoTest] Auto test disabled");
    }
}
```

### 9.4 驱动桥接规范

**在 `ETBattleDriverBridgeSystem.Update` 中驱动自动测试：**

```csharp
[EntitySystemOf(typeof(ETBattleComponent))]
[FriendOf(typeof(ETBattleAutoTestComponent))]
[FriendOf(typeof(ETBattleSkillTestComponent))]
[FriendOf(typeof(ETInputComponent))]
public static partial class ETBattleDriverBridgeSystem
{
    [EntitySystem]
    private static void Update(this ETBattleComponent self)
    {
        int currentFrame = ETBattleDriverBridge.GetCurrentFrame(self);

        // 1. Process auto test components
        ETBattleDriverBridge.ProcessAutoTest(self, currentFrame);
        ETBattleDriverBridge.ProcessSkillTest(self, currentFrame);

        // 2. Process input buffer
        ETBattleDriverBridge.ProcessInput(self, currentFrame);
    }
}
```

**`ETBattleDriverBridge.cs` 中的辅助方法：**

```csharp
public static class ETBattleDriverBridge
{
    /// <summary>
    /// Process auto test (move test)
    /// </summary>
    public static void ProcessAutoTest(ETBattleComponent self, int currentFrame)
    {
        var scene = self.Scene();
        var autoTest = scene?.GetComponent<ETBattleAutoTestComponent>();
        if (autoTest != null && autoTest.IsEnabled)
        {
            autoTest.OnUpdate(currentFrame);
        }
    }

    /// <summary>
    /// Process skill test
    /// </summary>
    public static void ProcessSkillTest(ETBattleComponent self, int currentFrame)
    {
        var scene = self.Scene();
        var skillTest = scene?.GetComponent<ETBattleSkillTestComponent>();
        if (skillTest != null && skillTest.IsEnabled)
        {
            skillTest.OnUpdate(currentFrame);
        }
    }

    /// <summary>
    /// Process input buffer
    /// </summary>
    public static void ProcessInput(ETBattleComponent self, int currentFrame)
    {
        var scene = self.Scene();
        var inputComponent = scene?.GetComponent<ETInputComponent>();
        if (inputComponent != null)
        {
            ETInputComponentSystem.ProcessInput(inputComponent, currentFrame);
        }
    }
}
```

## 十、输入处理规范

### 10.1 输入组件职责

```
┌─────────────────────────────────────────────────────────────────────────────┐
│ 输入处理流程 │
│ │
│ 自动测试组件 (AutoTest/SkillTest) │ │
│ │ AddMoveCommand / AddSkillCommand │ │
│ ▼ │ │
│ ETInputComponent (输入缓冲) │ │
│ │ GetInputsForFrame │ │
│ ▼ │ │
│ ETInputComponentSystem.ProcessInput │ │
│ │ ProcessMoveCommand / ProcessSkillCommand │ │
│ ▼ │ │
│ ETUnitComponent.GetUnit │ │
│ │ │
│ ▼ │ │
│ ETUnit.TargetX / TargetY │ │
│ │ │
└─────────────────────────────────────────────────────────────────────────────┘
```

### 10.2 输入命令定义

```csharp
public sealed record MoveCommand(int Frame, long ActorId, float X, float Y);
public sealed record SkillCommand(int Frame, long ActorId, int SkillSlot, float TargetX, float TargetY);
public sealed record StopCommand(int Frame, long ActorId);
```

### 10.3 输入处理禁止事项

| 禁止 | 说明 | 正确做法 |
|------|------|----------|
| ❌ 在输入处理中直接修改 ETUnit 位置 | 应设置 TargetX/Y | `unit.TargetX = cmd.X; unit.TargetY = cmd.Y;` |
| ❌ 在输入处理中计算伤害 | 应在 SkillCommand 中调用 `ExecuteDamage` | 使用 `unitComponent.ExecuteDamage()` |
| ❌ 跳过 ETInputComponent 直接操作 | 所有输入必须经过缓冲 | 使用 `AddMoveCommand` / `AddSkillCommand` |

## 十一、事件桥接规范

### 11.1 事件桥接职责

**`ETBattleViewEventSink` 将 AbilityKit 事件桥接到 ET 事件系统。**

```csharp
public sealed class ETBattleViewEventSink : IBattleViewEventSink
{
    private readonly ETBattleComponent _battleComponent;

    public void OnEnterGameSnapshot(in FrameSnapshotData snapshot)
    {
        var scene = _battleComponent.Scene();

        // 1. 发布 ActorSpawnEvent（触发 ETUnit 创建）
        foreach (var spawn in snapshot.ActorSpawns)
        {
            var evt = new ActorSpawnEvent { /* ... */ };
            EventSystem.Instance.Publish<Scene, ActorSpawnEvent>(scene, evt);
        }

        // 2. 初始化自动测试组件（在单位创建之后）
        InitializeAutoTestComponent(scene, snapshot);
    }
}
```

### 11.2 ActorSpawnEvent 处理器职责

**`ETBattleView_EventHandler` 负责创建 Logic 层和 View 层单位：**

```csharp
[Event(SceneType.DemoBattle)]
public class ETBattleView_EventHandler : AEvent<Scene, ActorSpawnEvent>
{
    protected override async ETTask Run(Scene scene, ActorSpawnEvent args)
    {
        // 1. 创建 Logic 层单位
        var unitComponent = scene.GetComponent<ETUnitComponent>();
        if (unitComponent != null)
        {
            unitComponent.CreateUnit(
                args.ActorId,
                args.EntityCode,
                args.Kind,
                args.Name,
                args.X,
                args.Y,
                args.MaxHp);
        }

        // 2. 创建 View 层单位视图
        var unitViewComponent = scene.GetComponent<ETUnitViewComponent>();
        unitViewComponent?.CreateUnitView(args);
    }
}
```

### 11.3 事件处理器命名

| 事件类型 | 处理器命名 | 示例 |
|----------|------------|------|
| `ActorSpawnEvent` | `ETBattleView_EventHandler` | `ActorSpawnEvent` 处理器 |
| `ActorMoveEvent` | `ETBattleView_ActorMove_Handler` | `ActorMoveEvent` 处理器 |
| `ActorDamageEvent` | `ETBattleView_ActorDamage_Handler` | `ActorDamageEvent` 处理器 |
| `ActorDeadEvent` | `ETBattleView_ActorDead_Handler` | `ActorDeadEvent` 处理器 |
| `BattleStartEvent` | `ETBattleView_BattleStart_Handler` | `BattleStartEvent` 处理器 |
| `BattleEndEvent` | `ETBattleView_BattleEnd_Handler` | `BattleEndEvent` 处理器 |

## 十二、初始化时序规范

### 12.1 战斗初始化顺序

```
1. ETBattleComponent.StartBattle()
   └── 创建 ETBattleAutoTestComponent
   └── 创建 ETBattleSkillTestComponent
   └── 通知 View 层战斗开始 (OnBattleStart)

2. ETMobaBattleDriver.TriggerEnterGameSnapshot()
   └── 调用 ETBattleViewEventSink.OnEnterGameSnapshot()
       └── 发布 ActorSpawnEvent（触发单位创建）
       └── 初始化自动测试组件（使用正确的 ActorId）

3. ETBattleView_EventHandler 处理 ActorSpawnEvent
   └── 创建 ETUnit
   └── 创建 ETUnitViewComponent

4. ETBattleDriverBridgeSystem.Update 每帧调用
   └── ProcessSkillTest（发送技能命令）
   └── ProcessAutoTest（发送移动命令）
   └── ProcessInput（处理输入缓冲）
```

### 12.2 自动测试组件初始化

**在 `ETBattleViewEventSink.OnEnterGameSnapshot` 中初始化：**

```csharp
private void InitializeAutoTestComponent(Scene scene, in FrameSnapshotData snapshot)
{
    var autoTest = scene.GetComponent<ETBattleAutoTestComponent>();
    var skillTest = scene.GetComponent<ETBattleSkillTestComponent>();

    if (autoTest == null && skillTest == null)
        return;

    // 使用第一个 spawn 的 ActorId
    long actorIdToUse = 0;
    if (snapshot.ActorSpawns?.Count > 0)
    {
        actorIdToUse = snapshot.ActorSpawns[0].ActorId;
    }

    if (autoTest != null)
    {
        autoTest.Initialize(actorIdToUse);
    }

    if (skillTest != null)
    {
        skillTest.Initialize(actorIdToUse);
    }
}
```

## 十三、调试建议

### 13.1 查看自动测试日志

```bash
