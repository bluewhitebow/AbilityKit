{
  "pipelineConfigs": [
    {
      "id": 1,
      "name": "技能释放管线",
      "description": "演示技能释放的完整流程",
      "phases": [
        {
          "name": "PreCheck",
          "type": "Instant",
          "duration": 0.0,
          "description": "预检查：目标是否有效、距离是否满足、冷却是否完成"
        },
        {
          "name": "Validation",
          "type": "Instant",
          "duration": 0.0,
          "description": "验证：检查资源是否足够、是否被沉默"
        },
        {
          "name": "Casting",
          "type": "Timed",
          "duration": 1.5,
          "description": "引导：播放施法动画，玩家可以取消"
        },
        {
          "name": "Execute",
          "type": "Timed",
          "duration": 0.2,
          "description": "执行：造成伤害、触发效果"
        },
        {
          "name": "Recovery",
          "type": "Timed",
          "duration": 0.5,
          "description": "收尾：动画复原、进入冷却"
        }
      ]
    },
    {
