<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>12</LangVersion>
    <RootNamespace>AbilityKit.Ability.Host.Extensions.Moba</RootNamespace>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DefineConstants>DOTNET</DefineConstants>
  </PropertyGroup>

  <!-- 引用 Unity/Packages 的 host.extension 核心文件 -->
  <ItemGroup>
    <!-- Room 核心（排除已存在于 AbilityKit.Protocol.Moba 中的文件） -->
    <Compile Include="..\..\Unity\Packages\com.abilitykit.host.extension\Runtime\Moba\Shared\Room\*.cs"
        Exclude="..\..\Unity\Packages\com.abilitykit.host.extension\Runtime\Moba\Shared\Room\MobaRoomCommandResult.cs" />
    <Compile Include="..\..\Unity\Packages\com.abilitykit.host.extension\Runtime\Moba\Server\Room\MobaRoomOrchestrator.cs" />
    <Compile Include="..\..\Unity\Packages\com.abilitykit.host.extension\Runtime\Moba\Shared\Struct\*.cs" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AbilityKit.Host\AbilityKit.Host.csproj" />
    <ProjectReference Include="..\AbilityKit.Protocol.Moba\AbilityKit.Protocol.Moba.csproj" />
    <ProjectReference Include="..\AbilityKit.Demo.Moba.Share\AbilityKit.Demo.Moba.Share.csproj" />
  </ItemGroup>

</Project>
