{
  "stateMachine": {
    "combatFSM": {
      "name": "Combat State Machine",
      "initialState": "Idle",
      "states": [
        {
          "name": "Idle",
          "onEnter": "PlayIdleAnimation",
          "onLogic": "CheckForEnemies",
          "onExit": "StopIdleAnimation",
          "transitions": ["Chase"],
          "properties": {
            "patrolRadius": 10.0,
            "detectionRange": 15.0
          }
        },
        {
          "name": "Chase",
          "onEnter": "PlayRunAnimation",
          "onLogic": "MoveToTarget",
          "onExit": "StopMoving",
          "transitions": ["Attack", "Idle"],
          "properties": {
            "moveSpeed": 5.0,
            "chaseDistance": 2.0
          }
        },
        {
          "name": "Attack",
          "onEnter": "PlayAttackAnimation",
          "onLogic": "CheckAttackRange",
          "onExit": "ResetAttackCooldown",
          "transitions": ["Chase", "Idle"],
          "properties": {
            "attackRange": 1.5,
            "attackDamage": 50.0,
            "attackCooldown": 1.5
          }
        },
        {
          "name": "Dead",
          "onEnter": "PlayDeathAnimation",
          "onLogic": "FadeOut",
          "onExit": "",
          "transitions": [],
          "properties": {
            "fadeDuration": 2.0
          }
        }
      ],
      "transitions": [
        {
          "from": "Idle",
          "to": "Chase",
          "condition": "EnemyDetected",
          "priority": 1
        },
        {
          "from": "Chase",
          "to": "Attack",
          "condition": "InAttackRange",
          "priority": 1
        },
        {
          "from": "Chase",
          "to": "Idle",
          "condition": "TargetLost",
          "priority": 0
        },
        {
          "from": "Attack",
          "to": "Chase",
          "condition": "TargetAlive",
          "priority": 1
        },
        {
          "from": "Attack",
          "to": "Idle",
          "condition": "TargetDead",
          "priority": 2
        }
      ]
    }
  },
