{
  "name": "CharacterFSM",
  "version": "1.0.0",
  "description": "角色状态机配置示例",
  "states": [
    {
      "id": "Idle",
      "type": "State",
      "description": "空闲状态",
      "onEnter": {
        "type": "Log",
        "message": "进入 Idle 状态"
      },
      "onLogic": {
        "type": "Composite",
        "children": [
          {
            "type": "Log",
            "message": "Idle 状态执行中..."
          }
        ]
      }
    },
    {
      "id": "Move",
      "type": "State",
      "description": "移动状态",
      "needsExitTime": false,
      "onEnter": {
        "type": "Log",
        "message": "进入 Move 状态"
      },
      "onLogic": {
        "type": "Log",
        "message": "Move: 移动中..."
      }
    },
    {
      "id": "Attack",
      "type": "State",
      "description": "攻击状态",
      "needsExitTime": true,
      "onEnter": {
        "type": "Log",
        "message": "进入 Attack 状态 - 开始攻击动画"
      },
      "onLogic": {
        "type": "Sequence",
        "children": [
          {
            "type": "Log",
            "message": "Attack: 攻击!"
          },
          {
            "type": "Wait",
            "duration": 0.5
          }
        ]
      },
      "onExit": {
        "type": "Log",
        "message": "离开 Attack 状态"
      }
    },
    {
      "id": "Dead",
      "type": "State",
      "description": "死亡状态",
      "needsExitTime": false,
      "onEnter": {
        "type": "Log",
        "message": "进入 Dead 状态"
      }
    }
  ],
  "transitions": [
    {
      "from": "Idle",
      "to": "Move",
      "condition": {
        "type": "Parameter",
        "name": "isMoving",
        "value": true
      },
      "description": " Idle -> Move"
    },
    {
      "from": "Idle",
      "to": "Attack",
      "condition": {
        "type": "Parameter",
        "name": "attackPressed",
        "value": true
      },
      "description": " Idle -> Attack"
    },
    {
      "from": "Move",
      "to": "Idle",
      "condition": {
        "type": "Parameter",
        "name": "isMoving",
        "value": false
      },
      "description": "Move -> Idle"
    },
    {
      "from": "Move",
      "to": "Attack",
      "condition": {
        "type": "Parameter",
        "name": "attackPressed",
        "value": true
      },
      "description": "Move -> Attack"
    },
    {
      "from": "Attack",
      "to": "Idle",
      "condition": {
        "type": "TimeElapsed",
        "duration": 1.0
      },
      "forceInstantly": false,
      "description": "Attack -> Idle (after animation)"
    },
    {
      "from": "*",
      "to": "Dead",
      "condition": {
        "type": "Parameter",
        "name": "health",
        "compare": "<=",
        "value": 0
      },
      "description": "任意状态 -> Dead"
    }
  ],
  "initialState": "Idle",
  "parameters": {
    "isMoving": {
      "type": "Bool",
      "defaultValue": false
    },
    "attackPressed": {
      "type": "Bool",
      "defaultValue": false
    },
    "health": {
      "type": "Float",
      "defaultValue": 100.0
    }
  }
}
